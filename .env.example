# Required
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
AUTH_SECRET=your-secret-key-here

# Optional — app URL (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Optional — email sending via SMTP (disabled if not set)
SMTP_HOST=smtp.example.com
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
SMTP_PORT=587
SMTP_FROM=noreply@example.com
CONTACT_EMAIL=hello@yourapp.com

# Optional — Vercel Blob storage (set automatically on Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Required for Vercel Cron jobs (weekly digest + event reminders).
# Generate a random value, e.g. cron-secret-9f2b7c1a... and add the SAME value
# to your Vercel project's Environment Variables. Vercel Cron sends it as
# "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=your-random-secret-here
