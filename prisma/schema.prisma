generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String?
  image           String?
  bio             String?
  location        String?
  country         String?
  canton          String?
  roles           String   @default("[\"PROFESSIONAL\"]")
  activityStatus  String   @default("ACTIVE_THIS_WEEK")
  emailVerified   Boolean  @default(false)
  verificationToken       String?
  verificationTokenExpiry DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastLoginAt     DateTime?

  investmentFocus String?
  preferredStage  String?
  ticketSizeMin   Int?
  ticketSizeMax   Int?
  portfolio       String?
  websiteUrl      String?
  portfolioUrl    String?
  portfolioProjects Json?
  githubUrl       String?
  linkedinUrl     String?
  openToMessages  Boolean  @default(true)

  identityVerified Boolean  @default(false)
  isEarlyMember    Boolean  @default(false)
  acceptedTerms    Boolean  @default(false)
  acceptedTermsAt  DateTime?
  confirmedAge     Boolean  @default(false)

  isStudent             Boolean  @default(false)
  dateOfBirth           DateTime?
  availableForMentoring Boolean  @default(false)
  mentoringStyle        String?
  mentorBio             String?

  averageRating   Float    @default(0)
  ratingCount     Int      @default(0)

  skills             UserSkill[]
  memberships        ProjectMember[]
  ownedProjects      Project[]      @relation("ProjectOwner")
  followedProjects   ProjectFollower[]
  joinRequests       JoinRequest[]
  sentMessages       Message[]      @relation("SentMessages")
  receivedMessages   Message[]      @relation("ReceivedMessages")
  projectPosts       ProjectPost[]
  eventPosts         EventPost[]
  conversations      ConversationParticipant[]
  ratingsGiven       Rating[]       @relation("RatingsGiven")
  ratingsReceived    Rating[]       @relation("RatingsReceived")
  notifications      Notification[]
  blockedUsers       BlockedUser[]  @relation("Blocker")
  blockedBy          BlockedUser[]  @relation("Blocked")
  reports            Report[]       @relation("Reporter")
  eventAttendance    EventAttendee[]
  organizedEvents    Event[]        @relation("EventOrganizer")
  reviewsGiven       Review[]       @relation("ReviewAuthor")
  reviewsReceived    Review[]       @relation("ReviewTarget")
  emailSubscriptions EmailSubscription[]
  bookmarks          Bookmark[]
  pinnedConversations ConversationPin[]
  projectUpdates     ProjectUpdate[]
  projectInterests   ProjectInterest[]
  schoolMemberships  SchoolMembership[]
  pledges            FundingPledge[]
  eventVotes         EventVote[]

  @@index([email])
  @@index([location])
}

model EmailSubscription {
  id         String   @id @default(cuid())
  email      String   @unique
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscribed Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Skill {
  id    String @id @default(cuid())
  name  String @unique
  users UserSkill[]
}

model UserSkill {
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}

model Project {
  id              String   @id @default(cuid())
  name            String
  logo            String?
  problem         String?
  solution        String?
  industry        String?
  secondaryIndustry String?
  stage           String   @default("IDEA")
  location        String   @default("Zurich")
  isRemote        Boolean  @default(false)
  teamSize        Int      @default(1)
  targetCustomer  String?
  scope           String?
  competitiveLandscape String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isDormant       Boolean  @default(false)
  followerCount   Int      @default(0)
  featured        Boolean  @default(false)

  schoolId          String?
  school            School?  @relation("SchoolProjects", fields: [schoolId], references: [id])
  isStudentProject  Boolean  @default(false)
  schoolClass       String?
  supervisor        String?
  // School affiliation approval: null = no affiliation, otherwise PENDING / APPROVED / REJECTED.
  // The school named by schoolId must approve before the project counts as an official school project.
  schoolAffiliation String?
  schoolApprovedAt  DateTime?
  schoolApprovedBy  String?

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  rolesNeeded     String?

  investorPitch   String?
  fundingAmount   Int?
  useOfFunds      String?
  tractionMetrics String?
  investorVisible Boolean  @default(false)
  seriousness     String?  @default("SIDE_PROJECT")
  teamCompensation String? @default("UNPAID")

  members      ProjectMember[]
  followers    ProjectFollower[]
  joinRequests JoinRequest[]
  faqs         FAQ[]
  posts        ProjectPost[]
  openRoles    OpenRole[]
  conversations Conversation[]
  ratings      Rating[]
  directMessages  Message[] @relation("MessageProject")
  bookmarks    Bookmark[]
  updates      ProjectUpdate[]
  interests    ProjectInterest[]
  fundraiser   Fundraiser?
  eventVotes   EventVote[]
  eventTeams   EventTeam[] @relation("ProjectEventTeams")

  @@index([stage])
  @@index([industry])
  @@index([location])
  @@index([schoolId])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  progress  String
  challenge String?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

model ProjectInterest {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleTitle String
  isFounder Boolean  @default(false)
  joinedAt  DateTime @default(now())

  @@unique([userId, projectId])
}

model ProjectFollower {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  isApproved Boolean  @default(false)
  followedAt DateTime @default(now())

  @@unique([userId, projectId])
}

model JoinRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  motivation    String
  experience    String
  availability  String
  applicantRole String?
  links         String?
  status        String   @default("PENDING")
  founderReply  String?
  createdAt    DateTime @default(now())
  reviewedAt   DateTime?

  @@unique([userId, projectId])
  @@index([projectId, status])
}

model OpenRole {
  id          String @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  skills      String
  commitment  String
  description String
}

model FAQ {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  order     Int     @default(0)
}

model ProjectPost {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId       String?
  author         User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content        String
  createdAt      DateTime @default(now())
  isAnnouncement Boolean  @default(false)
}

model Conversation {
  id              String   @id @default(cuid())
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  isGroup         Boolean  @default(false)
  pinnedByDefault Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages     Message[]
  participants ConversationParticipant[]
  pins         ConversationPin[]
}

model ConversationPin {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinned         Boolean      @default(true)

  @@unique([conversationId, userId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User      @relation("SentMessages", fields: [senderId], references: [id])
  receiverId     String?
  receiver       User?     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content        String
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  type      String   @default("NORMAL")
  projectId String?
  project   Project? @relation("MessageProject", fields: [projectId], references: [id], onDelete: SetNull)
  eventId   String?
  event     Event?   @relation("MessageEvent", fields: [eventId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
}

model Review {
  id          String   @id @default(cuid())
  reviewerId  String
  reviewer    User     @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  targetId    String
  target      User     @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  targetType  String
  rating      Int
  feedback    String
  emailSent   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Rating {
  id         String   @id @default(cuid())
  fromUserId String
  fromUser   User     @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("RatingsReceived", fields: [toUserId], references: [id])
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  stars      Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId, projectId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  content   String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model BlockedUser {
  blockerId String
  blocker   User   @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String
  blocked   User   @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@id([blockerId, blockedId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  targetId   String
  targetType String
  reason     String
  createdAt  DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  eventType   String
  organizerId String
  organizer   User     @relation("EventOrganizer", fields: [organizerId], references: [id])
  image       String?

  attendees EventAttendee[]
  posts     EventPost[]
  maxAttendees Int?
  requireApproval Boolean @default(false)
  locationScope String? // Local / National / International / Online
  directMessages  Message[] @relation("MessageEvent")

  schoolId          String?
  school            School?  @relation("SchoolEvents", fields: [schoolId], references: [id])
  isSchoolEvent     Boolean  @default(false)
  isPitchCompetition Boolean @default(false)
  maxTeamsPerSchool Int?
  prizeDescription  String?
  participatingSchools String? // JSON array of school ids
  votingClosed      Boolean  @default(false)
  votingClosedAt    DateTime?
  votes             EventVote[]
  teams             EventTeam[]
}

model EventTeam {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation("ProjectEventTeams", fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, projectId])
}

model EventPost {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content   String
  createdAt DateTime @default(now())

  @@index([eventId, createdAt])
}

model EventAttendee {
  id        String @id @default(cuid())
  eventId   String
  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  intention String
  reminder7dSent Boolean @default(false)
  reminder1dSent Boolean @default(false)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String
  message   String?
  createdAt DateTime @default(now())
}

model School {
  id           String   @id @default(cuid())
  name         String
  type         String   // GYMNASIUM, BERUFSSCHULE, UNIVERSITY, ORGANIZATION
  canton       String
  city         String
  website      String?
  contactName  String?
  contactEmail String?
  logo         String?
  description  String?
  verified     Boolean  @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())

  students     SchoolMembership[]
  projects     Project[] @relation("SchoolProjects")
  events       Event[]   @relation("SchoolEvents")

  @@index([verified])
}

model SchoolMembership {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("STUDENT") // STUDENT, TEACHER, MENTOR, ADMIN
  joinedAt  DateTime @default(now())

  @@unique([schoolId, userId])
}

model Fundraiser {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  goal          Int
  currentAmount Int      @default(0)
  currency      String   @default("CHF")
  description   String
  deadline      DateTime
  isActive      Boolean  @default(true)
  goalReachedNotified Boolean @default(false)
  closedAt      DateTime?
  closedBy      String?  // "auto" or "manual"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pledges  FundingPledge[]
  rewards  FundraiserReward[]
  vouchers Voucher[]
}

model FundraiserReward {
  id           String   @id @default(cuid())
  fundraiserId String
  fundraiser   Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)
  amount       Int
  description  String
  title        String
  limit        Int?
  claimed      Int      @default(0)
  createdAt    DateTime @default(now())

  pledges  FundingPledge[]
  vouchers Voucher[]
}

model FundingPledge {
  id           String   @id @default(cuid())
  fundraiserId String
  fundraiser   Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String
  email        String
  amount       Int
  message      String?
  status       String   @default("PLEDGED") // PLEDGED, CONFIRMED, CANCELLED
  rewardId     String?
  reward       FundraiserReward? @relation(fields: [rewardId], references: [id])
  voucher      Voucher?
  createdAt    DateTime @default(now())

  @@index([fundraiserId])
}

model Voucher {
  id           String   @id @default(cuid())
  code         String   @unique
  fundraiserId String
  fundraiser   Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)
  rewardId     String
  reward       FundraiserReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  pledgeId     String   @unique
  pledge       FundingPledge @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  usedAt       DateTime?
  usedBy       String?
  createdAt    DateTime @default(now())
}

model EventVote {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  voterId   String
  voter     User     @relation(fields: [voterId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, voterId])
  @@index([eventId, projectId])
}
